@page "/"
@inject IJSRuntime JS

<PageTitle>ヒミツジェネレーター</PageTitle>

<div class="mx-auto max-w-md px-4 py-8">
    <h1 class="text-2xl font-bold text-lime-700">ウマ娘 ヒミツジェネレーター</h1>
    <p class="mt-1 text-sm text-stone-500">「◯◯のヒミツ」風のカード画像を作れます。</p>

    <div class="mt-6">
        <div id="capture-target" class="bg-[#fdfcf9]">
            <div class="flex items-center justify-between rounded-t-md bg-gradient-to-b from-lime-500 to-lime-600 px-4 py-2.5 text-lg font-bold text-white">
                <span>@(string.IsNullOrWhiteSpace(CharacterName) ? "キャラクター名" : CharacterName)</span>
                <div class="flex items-center gap-1.5 pr-1">
                    <span class="h-5 w-[3px] -skew-x-[20deg] bg-[#ffffffe6]"></span>
                    <span class="h-5 w-[3px] -skew-x-[20deg] bg-[#ffffffe6]"></span>
                </div>
            </div>
            <div class="flex gap-3.5 rounded-b-xl border border-t-0 border-stone-200 bg-white p-4">
                <img src="@IconSrc" alt="icon" class="h-18 w-18 shrink-0 rounded-full object-cover" />
                <div class="min-w-0 flex-1">
                    <div class="mb-1.5 font-bold break-words text-amber-800">
                        @(string.IsNullOrWhiteSpace(CharacterName) ? "キャラクター名" : CharacterName)のヒミツ@(string.IsNullOrWhiteSpace(SecretNumber) ? "①" : SecretNumber)
                    </div>
                    <hr class="my-1.5 border-stone-200" />
                    <div class="leading-relaxed break-words whitespace-pre-wrap text-[0.95rem] text-stone-600">
                        @(string.IsNullOrWhiteSpace(SecretText) ? "ここにヒミツの本文が表示されます。" : SecretText)
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-8 space-y-3.5">
        <label class="block">
            <span class="mb-1 block text-sm font-bold text-stone-600">キャラクター名</span>
            <input @bind="CharacterName" @bind:event="oninput" maxlength="20" placeholder="例: スペシャルウィーク"
                   class="w-full rounded-md border border-stone-300 px-2.5 py-2 text-sm focus:border-lime-500 focus:outline-none" />
        </label>

        <label class="block">
            <span class="mb-1 block text-sm font-bold text-stone-600">ヒミツの番号</span>
            <input @bind="SecretNumber" @bind:event="oninput" maxlength="3" placeholder="①"
                   class="w-full rounded-md border border-stone-300 px-2.5 py-2 text-sm focus:border-lime-500 focus:outline-none" />
        </label>

        <label class="block">
            <span class="mb-1 block text-sm font-bold text-stone-600">ヒミツの本文</span>
            <textarea @bind="SecretText" @bind:event="oninput" rows="4" maxlength="200"
                      placeholder="例: 実は、利き牛乳ができる。"
                      class="w-full resize-y rounded-md border border-stone-300 px-2.5 py-2 text-sm focus:border-lime-500 focus:outline-none"></textarea>
        </label>

        <label class="block">
            <span class="mb-1 block text-sm font-bold text-stone-600">アイコン画像</span>
            <InputFile OnChange="OnIconSelected" accept="image/*" class="text-sm" />
        </label>
        @if (!string.IsNullOrEmpty(IconDataUrl))
        {
            <button class="text-xs text-blue-500 underline" @onclick="ClearIcon">画像をクリア（デフォルトアイコンに戻す）</button>
        }

        <button class="mt-3 w-full rounded-lg bg-lime-500 py-3 font-bold text-white hover:bg-lime-600" @onclick="DownloadPng">
            PNG画像としてダウンロード
        </button>
    </div>
</div>

@code {
    private const string DefaultIconPath = "image/chr_icon_round_0000.png";

    private string CharacterName = "なまえ";
    private string SecretNumber = "①";
    private string SecretText = "ヒミツを書いてね。";
    private string? IconDataUrl;

    private string IconSrc => IconDataUrl ?? DefaultIconPath;

    private async Task OnIconSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        const long maxSize = 5 * 1024 * 1024;
        using var stream = file.OpenReadStream(maxSize);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        var base64 = Convert.ToBase64String(ms.ToArray());
        IconDataUrl = $"data:{file.ContentType};base64,{base64}";
    }

    private void ClearIcon()
    {
        IconDataUrl = null;
    }

    private async Task DownloadPng()
    {
        var fileName = string.IsNullOrWhiteSpace(CharacterName)
            ? "himitsu.png"
            : $"{CharacterName}のヒミツ.png";
        await JS.InvokeVoidAsync("himitsuInterop.downloadElementAsPng", "capture-target", fileName);
    }
}
